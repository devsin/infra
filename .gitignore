# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# Sensitive variable files (local-only overrides)
# terraform.tfvars is gitignored; use *.auto.tfvars for CI-committed config
terraform.tfvars
!terraform.tfvars.example
**/envs/*.tfvars
!**/envs/*.tfvars.example

# Brand config (contains real org/brand names)
brands.yaml
!brands.yaml.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# OS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
*.swo

.temp.md
